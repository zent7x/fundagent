# Database
DATABASE_URL="file:./dev.db"

# Admin Configuration
# Set your admin wallet address here (the wallet that should have full admin access)
NEXT_PUBLIC_HEAD_ADMIN_WALLET="your-wallet-address-here"

# Admin master secret for message decryption (change this in production!)
ADMIN_MASTER_SECRET="your-secure-secret-here"

# Escrow Program (optional - for when you deploy the escrow contract)
NEXT_PUBLIC_ESCROW_PROGRAM_ID="your-program-id-here"
NEXT_PUBLIC_PLATFORM_AUTHORITY="your-authority-wallet-here"
