# =============================================================================
# FUNDAGENT ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control!
#
# Website: https://fundagent.io
# Developer: https://x.com/zent7x

# =============================================================================
# DATABASE
# =============================================================================

# Development (SQLite)
DATABASE_URL="file:./dev.db"

# Production (Supabase PostgreSQL)
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# =============================================================================
# ADMIN CONFIGURATION (Server-side only)
# =============================================================================

# Head admin wallet address - full access including encrypted message viewing
HEAD_ADMIN_WALLET="YOUR_ADMIN_WALLET_ADDRESS_HERE"

# Master secret for admin message decryption
# Generate with: openssl rand -base64 32
ADMIN_MASTER_SECRET="GENERATE_A_STRONG_SECRET_HERE"

# =============================================================================
# ESCROW CONFIGURATION
# =============================================================================

# Public escrow wallet address (where funds are held)
NEXT_PUBLIC_ESCROW_WALLET="YOUR_ESCROW_WALLET_PUBLIC_ADDRESS"

# Escrow wallet private key (base58 encoded) - KEEP SECRET!
ESCROW_WALLET_PRIVATE_KEY="YOUR_ESCROW_WALLET_PRIVATE_KEY"

# Platform authority wallet
NEXT_PUBLIC_PLATFORM_AUTHORITY="YOUR_PLATFORM_AUTHORITY_WALLET"

# =============================================================================
# SOLANA CONFIGURATION
# =============================================================================

# RPC endpoint
# Development: https://api.devnet.solana.com
# Production: https://api.mainnet-beta.solana.com
SOLANA_RPC_URL="https://api.devnet.solana.com"

# Network (devnet, testnet, mainnet-beta)
SOLANA_NETWORK="devnet"

# =============================================================================
# SECURITY
# =============================================================================

# Trust proxy headers (set to "true" if behind reverse proxy)
TRUST_PROXY="false"

# Redis for distributed rate limiting (optional)
# REDIS_URL="redis://localhost:6379"

# =============================================================================
# DEPLOYMENT CHECKLIST:
# =============================================================================
# [ ] Set up database (Supabase recommended for production)
# [ ] Generate ADMIN_MASTER_SECRET: openssl rand -base64 32
# [ ] Configure wallet addresses
# [ ] Set up escrow wallet with private key
# [ ] Run migrations: npx prisma migrate deploy
# [ ] For mainnet: Change SOLANA_RPC_URL and SOLANA_NETWORK
# =============================================================================
